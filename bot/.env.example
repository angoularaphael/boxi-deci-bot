# Deciplus
DECIPLUS_URL=https://boxingcenter.deciplus.pro/
DECIPLUS_USER=
DECIPLUS_PASSWORD=
DECIPLUS_HEADLESS=true
DECIPLUS_SLOW_MO=50
DECIPLUS_DEFAULT_SITE=Minimes

# Bot
BOT_DATA_DIR=data
BOT_SESSION_DIR=data/session
BOT_HTTP_PORT=3050
BOT_MAX_RETRIES=3
BOT_POLL_MS=5000
BOT_CATALOG_PUSH_ENABLED=true
BOT_CATALOG_PUSH_MS=21600000
# Keepalive session Deciplus (token ~4h) — ping toutes les 2h30
BOT_SESSION_KEEPALIVE_MS=9000000

# Badge — prélèvement IBAN différé (fenêtre coach 5-7 jours calendaires)
BADGE_PRELEVEMENT_DELAY_DAYS=7
BADGE_PRELEVEMENT_DELAY_MIN=5
BADGE_PRELEVEMENT_DELAY_MAX=7

# Push catalogue → boutique (Vercel)
STORE_INGEST_URL=https://box-plus.vercel.app/api/admin/ingest-catalog
SYNC_SECRET=change-me-in-production

# Alertes (optionnel)
ALERT_WEBHOOK_URL=
